# BasicPriceFlow

main: kit: flow: BasicPriceFlow:
{
  entity: "price",
  kind: "basic",
  name: "BasicPriceFlow",
  step: [
    {
      input: {
        ref: "price_ref01",
        srcdatavar: "price_ref01_data",
        suffix: "_dt0"
      }

      op: "load",
      valid: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-price_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicPriceFlow"
}